# Layer 1: Cuis VM
#
# Ubuntu 22.04 (glibc 2.35) is the minimum to run the included Squeak VM
# which requires glibc >= 2.34.
#
# This image contains ONLY the VM binary and its plugins.
# No image, no sources, no changesets.
# Build it once, cache it, reuse it in every CI run.
#
# Build:
#   docker build -f docker/Dockerfile.vm -t cuis-vm:latest .

FROM ubuntu:22.04

# Minimal runtime deps for the Squeak VM:
#   libssl3  — SqueakSSL plugin
#   libc6    — already in base, but explicit for clarity
#   libstdc++6, libgcc-s1 — needed by some .so plugins
# No X11, no audio: CI runs headless with vm-display-null and vm-sound-null.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      libssl3 \
      libstdc++6 \
      libgcc-s1 \
      ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Copy the x86_64 VM bundle (wrapper script + real binary + plugins)
COPY CuisVM.app/Contents/Linux-x86_64/ /opt/cuis-vm/
RUN chmod +x /opt/cuis-vm/squeak \
 && chmod +x /opt/cuis-vm/lib/squeak/*/squeak

# Smoke-test: VM must print its version and exit cleanly
RUN /opt/cuis-vm/squeak --version

ENV CUIS_VM=/opt/cuis-vm/squeak
ENV CUIS_VM_ARGS="-vm-sound-null -vm-display-null"

WORKDIR /workspace
