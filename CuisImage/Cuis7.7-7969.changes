!Object methodsFor: '[mk] comparing' library: #MinimalKernel01 stamp: 'ST-80 31/May/1983 09:10:35' prior: 16925864!
                        = anObject 
	"Answer true if the receiver and the argument represent the same object 
	and false otherwise. If = is redefined in any subclass, consider also
	redefining the message hash."

	^self == anObject! !
!Object methodsFor: '[mk] comparing' library: #MinimalKernel01 stamp: 'ST-80 31/May/1983 09:10:35' prior: 16925874!
                         ~= anObject 
	"Answer true if the receiver and the argument do not represent the same 
	object and false otherwise."

	^self = anObject == false! !
