		applierAt: self changeKeywordsSelectorOrderApplierId 
		ifAbsent: [ ChangeKeywordsSelectorOrderApplier ]! !
!RefactoringApplier class methodsFor: 'appliers - id' stamp: 'JEC 1/11/2026 10:26:03'!
