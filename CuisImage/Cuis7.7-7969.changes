!ClassDeletionChange methodsFor: 'fileIn/fileOut' stamp: 'jmv 7/May/2026 12:49:53' prior: 50350263!
                  fileOutOn: stream
	"File the receiver out on the given file stream"

	| record |

	record := String streamContents: [ :recordStream |
		recordStream
			nextPutAll: 'classRemoval: #';
			nextPutAll: className.
		appliesTo ifNotNil: [
			recordStream
				nextPutAll: ' restrictedTo: ';
				print: appliesTo ].
		recordStream
			nextPutAll: ' stamp: ';
			print: stamp ].

	stream
		nextPut: $!!;
		nextChunkPut: record;
		newLine;
		nextChunkPut: self command;
		newLine; newLine.! !
