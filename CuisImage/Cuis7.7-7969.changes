normalCursorWithMask
	"Cursor initNormalWithMask.  Cursor normalCursor show"
	"Next two lines work simply for any cursor..."
	"
	self initNormal.
	NormalCursor := CursorWithMask derivedFrom: NormalCursor.
	"
