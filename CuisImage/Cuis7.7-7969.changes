	self print: 'popIntoLit: ' , anAssociation key! !
!InstructionPrinter methodsFor: 'instruction decoding' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16893119!
                               popIntoTemporaryVariable: offset 
