!Dictionary methodsFor: '[mkHashedCollections] enumerating' library: #MinimalKernel04HashedCollections stamp: 'ST-80 31/May/1983 09:10:35' prior: 16850609!
     select: aBlock 
	"Evaluate aBlock with each of my values as the argument.  Collect into a new 
	dictionary, only those associations for which aBlock evaluates to true."

	| newCollection |
	newCollection := self species new.
	self associationsDo: 
		[:each | 
		(aBlock value: each value) ifTrue: [newCollection add: each]].
	^newCollection! !
