!CascadeNode methodsFor: 'printing' stamp: 'HAW 8/May/2026 12:28:50' prior: 16803802!
                               printOn: aStream indent: level precedence: p

	p > 0 ifTrue: [ aStream nextPut: $( ].
	messages first
		printReceiver: receiver
		on: aStream
		indent: level.
	1
		to: messages size
		do: [ :i | 
			aStream newLineTab: level + 1.
			(messages at: i)
				printOn: aStream
				indent: level.
