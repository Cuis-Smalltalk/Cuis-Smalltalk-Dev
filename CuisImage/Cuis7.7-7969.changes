!HoverHelpMorph methodsFor: 'initialization' stamp: 'jmv 27/Jan/2026 10:28:59' prior: 50332729!
  popUpForHand: aHand
	"Pop up the receiver as balloon help for the given hand"

	| dynamicContents newPos x y |
	dynamicContents := target
		ifNil: [ contents ]
		ifNotNil: [
			getter
				ifNotNil: [target perform: getter]
				ifNil: [target balloonText]].
	self contents: dynamicContents wrappedTo: nil.
	x := aHand morphPosition x - Cursor currentCursor width.
	y := aHand morphPosition y + Cursor currentCursor height.
	x + extent x > aHand world morphWidth ifTrue: [
		x := aHand world morphWidth - extent x ].
	y + extent y > aHand world morphHeight ifTrue: [
		y := aHand morphPosition y - extent y - 12 ].
	newPos := x@y.
	aHand world addMorphFront: self position: newPos.
	aHand balloonHelp: self.! !

----End fileIn of /Users/juanvuletich/Cuis-Smalltalk/Cuis-Smalltalk-Dev/CoreUpdates/7815-HoverHelp-MoveBelowBigCursor-JuanVuletich-2026Jan27-10h33m-jmv.001.cs.st----!

'From Cuis7.7 [latest update: #7815] on 27 January 2026 at 1:20:04 pm'!
!HoverHelpMorph methodsFor: 'initialization' stamp: 'jmv 27/Jan/2026 13:18:25' prior: 50338347!
          popUpForHand: aHand
	"Pop up the receiver as balloon help for the given hand"

	| dynamicContents newPos x y |
	dynamicContents := target
		ifNil: [ contents ]
		ifNotNil: [
			getter
				ifNotNil: [target perform: getter]
				ifNil: [target balloonText]].
	self contents: dynamicContents wrappedTo: nil.
	x := aHand morphPosition x - (extent x // 4)
		min: aHand world morphWidth - extent x - 10
		max: 10.
	y := aHand morphPosition y - extent y - 10.
	y < 5 ifTrue: [
		y := aHand morphPosition y + (Cursor currentCursor height * 3//2) ].
	newPos := x@y.
	aHand world addMorphFront: self position: newPos.
	aHand balloonHelp: self.! !

