!ChangeSet methodsFor: 'fileIn/Out' stamp: 'jmv 30/Apr/2026 10:00:26' prior: 16808916!
  fileOutMethodRemovalOf: selector for: class movedToOtherPackage: moved on: stream stamp: stamp 

	| methodReference changeRecord |
	
