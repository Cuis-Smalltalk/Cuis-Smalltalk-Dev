	^CurrentCursor! !
!BitBlt methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16790357!
    destOrigin: aPoint 
	"Set the destination coordinates to be those of aPoint."
	destX := aPoint x.
	destY := aPoint y! !
!BitBlt methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16790363!
                   destRect: aRectangle 
	"Set the destination coordinates to be those of aRectangle top left and
	the width and height of the receiver to be the width and height of aRectangle."
	destX := aRectangle left.
	destY := aRectangle top.
	width := aRectangle width.
	height := aRectangle height! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948706!
       bottom
	"Answer the position of the receiver's bottom horizontal line."
	^corner y! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948715!
                  bottomCenter
	"Answer the point at the center of the bottom horizontal line of the receiver."
	^self center x @ self bottom! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948722!
         bottomLeft
	"Answer the point at the left edge of the bottom horizontal line of the receiver."
	^origin x @ corner y! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948728!
                bottomRight
	"Answer the point at the right edge of the bottom horizontal line of the receiver."
	^corner! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948737!
                           center
	"Answer the point at the center of the receiver."
	^self topLeft + self bottomRight // 2! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948743!
    corner
	"Answer the point at the bottom right corner of the receiver."
	^corner! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948757!
                     extent
	"Answer with a rectangle with origin 0@0 and corner the receiver's 
	width @ the receiver's height."
	^corner - origin! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948764!
      height
	"Answer the height of the receiver."
	^corner y - origin y! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948781!
  left
	"Answer the position of the receiver's left vertical line."
	^origin x! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948790!
                        leftCenter
	"Answer the point at the center of the receiver's left vertical line."
	^self left @ self center y! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948796!
                      origin
	"Answer the point at the top left corner of the receiver."
	^origin! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948801!
                         right
	"Answer the position of the receiver's right vertical line."
	^corner x! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948810!
                      rightCenter
	"Answer the point at the center of the receiver's right vertical line."
	^self right @ self center y! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948816!
                   top
	"Answer the position of the receiver's top horizontal line."
	^origin y! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948825!
                        topCenter
	"Answer the point at the center of the receiver's top horizontal line."
	^self center x @ self top! !
!Rectangle methodsFor: 'accessing' stamp: 'ST-80 31/May/1983 09:10:35' prior: 16948831!
                       topLeft
	"Answer the point at the top left corner of the receiver's top horizontal line."
	^origin! !
