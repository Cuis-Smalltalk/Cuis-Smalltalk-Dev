!AbstractVectorCanvas class methodsFor: 'literal path data' stamp: 'jmv 25/Jun/2026, 2:31:02 pm (UTC)' prior: 16779385!
     pushPinIconData: aSize
	| scale |
	(IconPathData at: #pushPinIconSize ifAbsent: nil) = aSize ifTrue: [
		IconPathData at: #pushPinIcon ifPresent: [ :found | ^found ]].
	IconPathData at: #pushPinIconSize put: aSize.
	scale := aSize / 19.0.
	^IconPathData at: #pushPinIcon put: (
		self scalePathData: #[
			0 0 21
			1 10 13
			1 15 18
			1 14 13
			1 21 6
			1 15 0
			1 8 7
			1 3 6
			1 8 11
			1 0 21
		] scale: scale)! !
