!TranscriptMorph methodsFor: 'events' stamp: 'len 22/Jun/2026, 8:38:55 am (UTC)'!
            keyStroke: anEvent
	(anEvent commandAltKeyPressed and: [anEvent keyCharacter = $l]) ifTrue: [^ self clearInternal].
